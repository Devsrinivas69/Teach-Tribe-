# YouTube Video Suggestions - Environment Configuration Template

# ============================================
# Backend API Configuration
# ============================================

# Port where the video suggestion API runs
VIDEO_API_PORT=3001

# Frontend URL for CORS configuration
# Used to allow requests from the frontend
FRONTEND_URL=http://localhost:5173

# ============================================
# YouTube Data API v3 Configuration
# ============================================

# Your YouTube API Key
# Get from: https://console.cloud.google.com/
# 1. Create project
# 2. Enable "YouTube Data API v3"
# 3. Create API key credential
# Keep this secure - use environment variables in production
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: YouTube API quota alerts
# Set to true to enable logging when approaching quota limits
YOUTUBE_QUOTA_ALERTS=false

# ============================================
# Firebase Configuration
# ============================================

# Your Firebase project config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# Frontend Configuration
# ============================================

# YouTube Data API v3 key for instructor video search (frontend)
# Used by the YouTube video search in Create Course
# Restrict this key to HTTP referrers (your domain) in Google Cloud Console
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Custom video API URL (optional)
# If running API on different server/port
VITE_VIDEO_API_URL=http://localhost:3001/api/videos
VITE_AUTH_API_URL=http://localhost:3001/api/auth

# Enable debug logging in frontend
VITE_DEBUG=false

# ============================================
# Video Search Configuration
# ============================================

# Maximum videos to fetch per search query
YOUTUBE_MAX_RESULTS_PER_QUERY=5

# Video duration preference for search
# Options: short (< 4 min), medium (4-20 min), long (> 20 min)
YOUTUBE_PREFERRED_DURATION=medium

# Search result ordering
# Options: relevance, rating, viewCount, videoCount
YOUTUBE_SEARCH_ORDER=relevance

# ============================================
# Admin Features
# ============================================

# Enable auto-approval for high-engagement videos
ENABLE_AUTO_APPROVE=false

# Minimum engagement score (0-100) for auto-approval
AUTO_APPROVE_THRESHOLD=85

# Enable batch video processing
ENABLE_BATCH_PROCESSING=true

# Maximum videos to process in batch
BATCH_PROCESSING_LIMIT=20

# ============================================
# Feature Flags
# ============================================

# Show video engagement metrics in dashboard
SHOW_ENGAGEMENT_METRICS=true

# Show channel information
SHOW_CHANNEL_INFO=true

# Allow instructors to suggest videos
ALLOW_INSTRUCTOR_SUGGESTIONS=true

# Enable video analytics tracking
TRACK_VIDEO_ANALYTICS=true

# ============================================
# Logging Configuration
# ============================================

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# Log API requests to console
LOG_API_REQUESTS=false

# ============================================
# Development Configuration
# ============================================

# Environment type: development, staging, production
NODE_ENV=development

# Enable detailed error messages
VERBOSE_ERRORS=true

# ============================================
# Password Reset OTP Configuration
# ============================================

# Firebase Admin initialization (set one of these)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=./server/firebase-service-account.json

# SMTP email delivery for OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=your_app_password
PASSWORD_RESET_FROM_EMAIL=no-reply@teachtribe.com
PASSWORD_RESET_APP_NAME=TeachTribe

# OTP policies
PASSWORD_RESET_OTP_TTL_MS=600000
PASSWORD_RESET_RESEND_COOLDOWN_MS=60000
PASSWORD_RESET_MAX_OTP_ATTEMPTS=5
PASSWORD_RESET_TOKEN_TTL_MS=600000

# ============================================
# IMPORTANT NOTES
# ============================================

# 1. Never commit this file with actual keys to git
#    - Use .gitignore: .env, .env.local, .env.*.local
#    - Create example file: .env.example with placeholder values
#
# 2. YouTube API Key Security
#    - Restrict API key to server IP in production
#    - Use separate keys for dev/staging/production
#    - Rotate keys periodically
#    - Monitor usage at: https://console.cloud.google.com/
#
# 3. Different configurations for different environments:
#    - .env.local - Local development (not committed)
#    - .env.staging - Staging environment
#    - .env.production - Production (use secrets manager)
#
# 4. Loading Order (use first existing file):
#    1. .env.local
#    2. .env.{NODE_ENV}.local
#    3. .env
#
# 5. Required for MVP:
#    - YOUTUBE_API_KEY
#    - VITE_SUPABASE_URL
#    - VITE_SUPABASE_ANON_KEY
#
# 6. Recommended for Production:
#    - Use AWS Secrets Manager / Azure Key Vault
#    - Rotate API keys quarterly
#    - Use separate API keys per environment
#    - Enable API key restrictions (IP, referrer)
